{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mavs-research.local/schemas/phase2_trace.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["run_id", "implementation_git_sha", "generation", "method_name", "opportunity_id", "world_id", "domain", "step", "scenario_class", "composition_id", "corruption_families_json", "decision", "risk_score", "unsafe", "uar_error", "frr_error", "escalated", "catastrophic_error", "evidence_status", "correlation_presence", "harmful_correlation", "safe_consistency", "danger_witness", "safe_witness", "ambiguity", "provenance_concentration", "independence", "source_compromise", "counterfactual_decision", "counterfactual_fragility", "drop_one_fragility", "raw_correlation_only", "raw_correlation_only_veto", "hard_veto", "bounded_mitigation", "feedback_release_step", "feedback_reliability", "feedback_poisoned", "feedback_disposition", "change_active", "recovery_active", "intervention_loss", "trace_lineage_sha256"],
  "properties": {
    "run_id": {"type": "string", "minLength": 1},
    "implementation_git_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "generation": {"type": "integer", "minimum": 1, "maximum": 3},
    "method_name": {"enum": ["ds_cf", "visible_risk_threshold", "provenance_selective"]},
    "opportunity_id": {"type": "string", "minLength": 1},
    "world_id": {"type": "string", "minLength": 1},
    "domain": {"type": "string", "minLength": 1},
    "step": {"type": "integer", "minimum": 0, "maximum": 99},
    "scenario_class": {"enum": ["safe_correlated_agreement", "harmful_collapse", "ambiguous_masking", "mixed"]},
    "composition_id": {"type": "string", "pattern": "^p2c[0-9]{2}$"},
    "corruption_families_json": {"type": "string"},
    "decision": {"enum": ["accept", "reject", "escalate"]},
    "risk_score": {"type": "number", "minimum": 0, "maximum": 1},
    "unsafe": {"type": "boolean"},
    "uar_error": {"type": "boolean"},
    "frr_error": {"type": "boolean"},
    "escalated": {"type": "boolean"},
    "catastrophic_error": {"type": "boolean"},
    "evidence_status": {"enum": ["available", "absent", "unavailable", "masked"]},
    "correlation_presence": {"type": "number", "minimum": 0, "maximum": 1},
    "harmful_correlation": {"type": "number", "minimum": 0, "maximum": 1},
    "safe_consistency": {"type": "number", "minimum": 0, "maximum": 1},
    "danger_witness": {"type": "boolean"},
    "safe_witness": {"type": "boolean"},
    "ambiguity": {"type": "number", "minimum": 0, "maximum": 1},
    "provenance_concentration": {"type": "number", "minimum": 0, "maximum": 1},
    "independence": {"type": "number", "minimum": 0, "maximum": 1},
    "source_compromise": {"type": "number", "minimum": 0, "maximum": 1},
    "counterfactual_decision": {"enum": ["accept", "reject", "escalate"]},
    "counterfactual_fragility": {"type": "boolean"},
    "drop_one_fragility": {"type": "number", "minimum": 0, "maximum": 1},
    "raw_correlation_only": {"type": "boolean"},
    "raw_correlation_only_veto": {"type": "boolean"},
    "hard_veto": {"type": "boolean"},
    "bounded_mitigation": {"type": "number", "minimum": 0, "maximum": 0.12},
    "feedback_release_step": {"type": ["integer", "null"]},
    "feedback_reliability": {"type": "number", "minimum": 0, "maximum": 1},
    "feedback_poisoned": {"type": "boolean"},
    "feedback_disposition": {"enum": ["accepted", "quarantined", "censored", "unreleased"]},
    "change_active": {"type": "boolean"},
    "recovery_active": {"type": "boolean"},
    "intervention_loss": {"type": "number", "minimum": 0},
    "trace_lineage_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  }
}
