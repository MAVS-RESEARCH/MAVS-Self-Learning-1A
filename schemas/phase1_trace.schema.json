{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mavs-research.local/schemas/phase1_trace.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["run_id", "implementation_git_sha", "generation", "method_name", "condition", "opportunity_id", "world_id", "domain", "step", "schedule_family", "shift_class", "change_active", "recovery_active", "decision", "risk_score", "unsafe", "feedback_release_step", "feedback_observed_by_step", "uar_error", "frr_error", "escalated", "catastrophic_error", "intervention_loss", "oracle_loss", "released_feedback_count", "calibration_examples", "calls", "tokens", "latency_ms", "wall_time_ms", "memory_bytes", "update_operations", "configuration_switches"],
  "properties": {
    "run_id": {"type": "string", "minLength": 1},
    "implementation_git_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "generation": {"type": "integer", "minimum": 1, "maximum": 3},
    "method_name": {"type": "string", "minLength": 1},
    "condition": {"enum": ["fixed", "cumulative", "fresh"]},
    "opportunity_id": {"type": "string", "minLength": 1},
    "world_id": {"type": "string", "minLength": 1},
    "domain": {"type": "string", "minLength": 1},
    "step": {"type": "integer", "minimum": 0, "maximum": 99},
    "schedule_family": {"type": "string", "minLength": 1},
    "shift_class": {"enum": ["abrupt", "gradual", "recurring", "mixed"]},
    "change_active": {"type": "boolean"},
    "recovery_active": {"type": "boolean"},
    "decision": {"enum": ["accept", "reject", "escalate"]},
    "risk_score": {"type": "number", "minimum": 0, "maximum": 1},
    "unsafe": {"type": "boolean"},
    "feedback_release_step": {"type": ["integer", "null"]},
    "feedback_observed_by_step": {"type": "boolean"},
    "uar_error": {"type": "boolean"},
    "frr_error": {"type": "boolean"},
    "escalated": {"type": "boolean"},
    "catastrophic_error": {"type": "boolean"},
    "intervention_loss": {"type": "number", "minimum": 0},
    "oracle_loss": {"type": "number", "minimum": 0},
    "released_feedback_count": {"type": "integer", "minimum": 0},
    "calibration_examples": {"type": "integer", "minimum": 0},
    "calls": {"type": "integer", "minimum": 0},
    "tokens": {"type": "integer", "minimum": 0},
    "latency_ms": {"type": "number", "minimum": 0},
    "wall_time_ms": {"type": "number", "minimum": 0},
    "memory_bytes": {"type": "integer", "minimum": 0},
    "update_operations": {"type": "integer", "minimum": 0},
    "configuration_switches": {"type": "integer", "minimum": 0}
  }
}
