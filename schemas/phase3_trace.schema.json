{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mavs-research.local/schemas/phase3_trace.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["run_id", "implementation_git_sha", "generation", "condition", "opportunity_id", "world_id", "curriculum_id", "curriculum_step", "stage", "domain", "config_id", "config_hash", "decision", "risk", "severity", "threshold", "safe_witness", "danger_witness", "query_used", "selector_applicability", "selector_fallback", "reason_codes_json", "meta_diagnostics_json", "visible_features_json", "specialist_outputs_json", "prefeedback_record_hash", "outcome_record_hash", "feedback_disposition", "feedback_reliability", "unsafe", "uar_error", "frr_error", "escalated", "terminal_error", "target_exposure", "learning_event_id", "candidate_id", "certification_report_id", "update_action", "rollback_id", "trace_lineage_sha256"],
  "properties": {
    "run_id": {"type": "string", "minLength": 1},
    "implementation_git_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "generation": {"enum": [1, 2, 3]},
    "condition": {"enum": ["cumulative", "fresh"]},
    "opportunity_id": {"type": "string", "minLength": 1},
    "world_id": {"type": "string", "minLength": 1},
    "curriculum_id": {"type": "string", "pattern": "^R(0[1-9]|10)$"},
    "curriculum_step": {"type": "integer", "minimum": 0, "maximum": 1999},
    "stage": {"enum": ["discovery", "containment", "proposal", "certification", "shadow", "recurrence", "rollback_challenge", "transfer"]},
    "domain": {"type": "string", "minLength": 1},
    "config_id": {"type": "string", "minLength": 1},
    "config_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "decision": {"enum": ["accept", "reject", "escalate"]},
    "risk": {"type": "number", "minimum": 0, "maximum": 1},
    "severity": {"type": "number", "minimum": 0, "maximum": 1},
    "threshold": {"type": "number", "minimum": 0, "maximum": 1},
    "safe_witness": {"type": "boolean"},
    "danger_witness": {"type": "boolean"},
    "query_used": {"type": "boolean"},
    "selector_applicability": {"type": "number", "minimum": 0, "maximum": 1},
    "selector_fallback": {"type": "boolean"},
    "reason_codes_json": {"type": "string", "minLength": 2},
    "meta_diagnostics_json": {"type": "string", "minLength": 2},
    "visible_features_json": {"type": "string", "minLength": 2},
    "specialist_outputs_json": {"type": "string", "minLength": 2},
    "prefeedback_record_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "outcome_record_hash": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"},
    "feedback_disposition": {"enum": ["accepted", "quarantined", "censored", "unreleased"]},
    "feedback_reliability": {"type": "number", "minimum": 0, "maximum": 1},
    "unsafe": {"type": "boolean"},
    "uar_error": {"type": "boolean"},
    "frr_error": {"type": "boolean"},
    "escalated": {"type": "boolean"},
    "terminal_error": {"type": "boolean"},
    "target_exposure": {"type": "boolean"},
    "learning_event_id": {"type": ["string", "null"]},
    "candidate_id": {"type": ["string", "null"]},
    "certification_report_id": {"type": ["string", "null"]},
    "update_action": {"type": ["string", "null"], "enum": ["promote", "reject", "quarantine", "rollback", null]},
    "rollback_id": {"type": ["string", "null"]},
    "trace_lineage_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  }
}
