{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mavs-research.local/schemas/learning_event.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["event_id", "trigger", "trace_ids", "attributed_mechanism", "candidate_operations", "evidence_sufficient", "feedback_provenance", "feedback_reliability"],
  "properties": {
    "event_id": {"type": "string", "minLength": 1}, "trigger": {"type": "string", "minLength": 1},
    "trace_ids": {"type": "array", "minItems": 1, "items": {"type": "string"}, "uniqueItems": true},
    "attributed_mechanism": {"type": "string", "minLength": 1},
    "candidate_operations": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "evidence_sufficient": {"type": "boolean"}, "feedback_provenance": {"type": "string", "minLength": 1},
    "feedback_reliability": {"type": "number", "minimum": 0, "maximum": 1}
  }
}
