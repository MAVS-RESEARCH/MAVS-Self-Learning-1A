{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mavs-research.local/schemas/phase2_failure_card.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["card_id", "run_id", "generation", "method_name", "world_id", "step", "opportunity_id", "failure_type", "expected_action", "actual_action", "visible_evidence", "hidden_mechanism_after_reveal", "specialist_state_hash", "diagnostic_trace", "immediate_containment", "suspected_cause", "trace_lineage_sha256", "card_sha256"],
  "properties": {
    "card_id": {"type": "string", "minLength": 1},
    "run_id": {"type": "string", "minLength": 1},
    "generation": {"type": "integer", "minimum": 1, "maximum": 3},
    "method_name": {"type": "string", "minLength": 1},
    "world_id": {"type": "string", "minLength": 1},
    "step": {"type": "integer", "minimum": 0, "maximum": 99},
    "opportunity_id": {"type": "string", "minLength": 1},
    "failure_type": {"enum": ["unsafe_acceptance", "false_rejection"]},
    "expected_action": {"type": "string"},
    "actual_action": {"type": "string"},
    "visible_evidence": {"type": "object"},
    "hidden_mechanism_after_reveal": {"type": "object"},
    "specialist_state_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "diagnostic_trace": {"type": "object"},
    "immediate_containment": {"type": "string"},
    "suspected_cause": {"type": "string"},
    "trace_lineage_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "card_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  }
}
