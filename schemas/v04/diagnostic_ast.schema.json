{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mavs.local/schemas/v04/diagnostic_ast.schema.json",
  "title": "MAVS executable diagnostic AST",
  "$ref": "#/$defs/node",
  "$defs": {
    "node": {
      "type": "object",
      "required": ["op"],
      "properties": {
        "op": {"enum": ["feature", "parameter", "constant", "and", "or", "not", "gte", "gt", "lte", "lt", "eq", "add", "sub", "mul", "min", "max", "clip"]},
        "name": {"type": "string", "minLength": 1},
        "value": {"type": ["number", "boolean"]},
        "children": {"type": "array", "items": {"$ref": "#/$defs/node"}, "minItems": 1},
        "left": {"$ref": "#/$defs/node"},
        "right": {"$ref": "#/$defs/node"},
        "lower": {"type": "number"},
        "upper": {"type": "number"}
      },
      "additionalProperties": false
    }
  }
}
