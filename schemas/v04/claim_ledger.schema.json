{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "claim_ledger.schema.json",
  "type": "object",
  "required": ["schema_version", "generated", "claims", "source_audit_sha256"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "generated": {"const": true},
    "generator": {"type": "string", "minLength": 1},
    "source_audit_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "claims": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["claim_id", "status", "required_gates", "gate_results", "scope", "artifact_hashes", "maximum_permitted_language"],
        "properties": {
          "status": {"enum": ["supported", "partially_supported", "unsupported", "falsified"]}
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}
